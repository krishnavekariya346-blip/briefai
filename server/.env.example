PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/briefai
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_URL=http://localhost:5173

# --- AI (100% free options — pick one) ---
# mock = no key needed (template only)
# gemini = free key https://aistudio.google.com/apikey
# groq = free key https://console.groq.com/keys
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Optional: used for Pro plan generations (defaults to GEMINI_MODEL)
GEMINI_PRO_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_PRO_MODEL=llama-3.3-70b-versatile

# --- Billing ---
# demo = instant Pro upgrade in Settings (no Stripe) — best for local portfolio demos
# stripe = use Stripe Checkout (requires keys below)
# disabled = no upgrade unless you add Stripe
# Default in development: demo if Stripe keys are missing
BILLING_MODE=demo

# Stripe TEST keys are FREE — https://dashboard.stripe.com/test/apikeys
# Test card: 4242 4242 4242 4242 (no real money)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

FREE_PROPOSAL_LIMIT=3

# --- Email (Pro notifications) ---
# Brevo (recommended): https://www.brevo.com → SMTP & API → create SMTP key
EMAIL_USE_ETHEREAL=false
EMAIL_ENABLED=true
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@email.com
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=your-brevo-login@email.com

# Or leave SMTP empty + EMAIL_USE_ETHEREAL=true for dev preview links only (no real inbox)
